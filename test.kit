section .text
    entry _main

_hi:
    copy %ax, 75
    out %ax             ; prints K

    copy %ax, 105
    out %ax             ; prints i

    copy %ax, 116
    out %ax             ; prints t

    jmp _end

_main:
    copy %ax, 35
    out %ax             ; prints #

    jmp _hi

_end:
    copy %ax, 10
    out %ax             ; prints \n
