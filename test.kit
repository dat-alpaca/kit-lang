section .data
    wb hashtag      , 35, 0, 0, 0, 0, 0, 0, 0
    wb m0           , 75, 73, 84, 0, 0, 0, 0, 0
    wb endl         , 10, 0, 0, 0, 0, 0, 0, 0

section .text
    entry _main

_hi:
    copy %ax, [m0]      
    out %ax                 ; prints Kit             

    jmp _end

_main:
    copy %ax, [hashtag]     
    out %ax                 ; prints #

    jmp _hi

_end:
    copy %ax, [endl]
    out %ax                 ; prints \n
